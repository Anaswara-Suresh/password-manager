# ============================================================
#  LockBox — .gitignore
# ============================================================

# ---------- User vault data (NEVER commit) ----------
# The encrypted password database is per-user data, not source.
LockBox/lockbox.db
*.db
*.db-journal
*.db-wal
*.db-shm

# ---------- Build artifacts ----------
build/
LockBox/build/
out/
bin/
lib/

# CMake
CMakeCache.txt
CMakeFiles/
CMakeScripts/
cmake_install.cmake
install_manifest.txt
Testing/
CTestTestfile.cmake
*.cbp
compile_commands.json

# C / C++ object & binary files
*.o
*.obj
*.a
*.la
*.lo
*.lib
*.dll
*.so
*.so.*
*.dylib
*.exe
*.out
*.app
*.exp
*.pdb
*.ilk
*.idb

# ---------- Qt artifacts ----------
# Auto-generated by moc, uic, rcc — should never be committed.
moc_*.cpp
moc_*.h
qrc_*.cpp
ui_*.h
*.qmlc
*.jsc
*_plugin_import.cpp

# Qt Creator per-user files
*.user
*.user.*
*.autosave
*.qtcreator/CMakeLists.txt.user
*.qtcreator/CMakeLists.txt.user.*
.qtcreator/

# Qt translations (compiled)
*.qm

# ---------- IDE / editor files ----------
# Note: .vscode/settings.json is intentionally tracked as a team-shared file.
#       Other VS Code junk is excluded.
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# JetBrains
.idea/
*.iml

# Vim / Emacs
*.swp
*.swo
*.swn
*~
.\#*
\#*\#

# Sublime Text
*.sublime-project
*.sublime-workspace

# ---------- Operating system noise ----------
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes
__MACOSX/

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*:Zone.Identifier

# Linux
*~
.fuse_hidden*
.Trash-*

# ---------- Logs & debugging ----------
*.log
*.tmp
*.bak
*.cache
.cache/

# ---------- Python (in case any tooling scripts get added) ----------
__pycache__/
*.py[cod]
*.egg-info/
venv/
.venv/

# ---------- Secrets ----------
.env
.env.local
*.pem
*.key
secrets/

# ---------- Local-only folders (not part of the project) ----------
# Personal notes / docs folder kept locally, not tracked
LockBox-An-offline-Password-Manager/